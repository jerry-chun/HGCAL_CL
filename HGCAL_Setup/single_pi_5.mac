/process/em/verbose 0
/process/had/verbose 0
/run/initialize
/HGCAL/gun/particleTypes "pi-"
/HGCAL/gun/numParticlesMin 1
/HGCAL/gun/numParticlesMax 1
/HGCAL/gun/energyMin 50 GeV
/HGCAL/gun/energyMax 50 GeV
/HGCAL/gun/thetaMin 0 deg
/HGCAL/gun/thetaMax 1 deg
/HGCAL/gun/zMin -900 cm
/HGCAL/gun/zMax -899 cm
/run/printProgress 1
/run/beamOn 5
