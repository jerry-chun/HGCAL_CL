/run/numberOfThreads 1
/process/em/verbose 0
/process/had/verbose 0
/run/initialize

/HGCAL/gun/particleTypes "e-"
/HGCAL/gun/numParticlesMin 1
/HGCAL/gun/numParticlesMax 3
/HGCAL/gun/energyMin 20 GeV
/HGCAL/gun/energyMax 200 GeV
/HGCAL/gun/thetaMin 0 deg
/HGCAL/gun/thetaMax 1 deg
/HGCAL/gun/zMin -900 cm
/HGCAL/gun/zMax -899 cm

/run/printProgress 1
/run/beamOn 5
