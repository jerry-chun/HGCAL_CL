universe        = vanilla
getenv          = True

executable      = /bin/bash
arguments       = /vols/cms/mm1221/Independent/Files_merge/merge.sh $(HITS) $(LC)

# Resources
request_cpus    = 1
request_memory  = 1 GB
request_disk    = 1 GB
+MaxRuntime     = 3600

# Logs
output          = /vols/cms/mm1221/Independent/Files_merge/logs/$(ClusterId).$(ProcId).out
error           = /vols/cms/mm1221/Independent/Files_merge/logs/$(ClusterId).$(ProcId).err
log             = /vols/cms/mm1221/Independent/Files_merge/logs/cluster.$(ClusterId).log

# Queue from 2-column file (HITS LC)
queue HITS, LC from /vols/cms/mm1221/Independent/LC_scripts/LC_in/photons_2_pairs.txt

